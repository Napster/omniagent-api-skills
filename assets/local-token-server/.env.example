# Napster Omniagent — local token server environment
# Copy this file to `.env` (same folder) and fill in your values.
# `.env` holds your API key — it MUST be gitignored. See gitignore.template.

# Required. Your Napster API key. Server-side only — never exposed to the browser.
NAPSTER_API_KEY=

# --- Preferred: connect through an Omniagent --------------------------------
# The agent already owns the persona, voice, tools, knowledge, and provider
# settings. Set this and the token server uses
# POST /public/agents/{AGENT_ID}/connections.
AGENT_ID=

# Channel for the connection: "webrtc" (default) or "websocket".
CHANNEL_TYPE=webrtc

# Optional. A stable per-user id (^[A-Za-z0-9_-]{1,32}$) to enable cross-session
# memory. Hash UUIDs/emails down to this format before passing them.
EXTERNAL_CLIENT_ID=

# --- Fallback: assemble a session from a persona ----------------------------
# Only used when AGENT_ID is empty. Calls POST /public/connections with an
# explicit providerConfig. Prefer the agent path above.
COMPANION_ID=
COMPANION_VOICE=alloy
# Comma-separated function IDs to bind on the connection (e.g. fn_a,fn_b).
COMPANION_FUNCTIONS=

# Optional. Override the API base URL (defaults to the production endpoint).
# COMPANION_API_BASE=https://companion-api.napster.com
